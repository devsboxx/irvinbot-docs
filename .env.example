# Base de datos — para desarrollo local usa localhost:5432
# En Docker el docker-compose sobreescribe DATABASE_URL automáticamente
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/irvinbot_docs

# JWT — CRÍTICO: debe ser idéntico en auth, chat, docs y gateway
# Genera uno con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-secreto-igual-en-todos-los-servicios
ALGORITHM=HS256

# ── Embeddings ────────────────────────────────────────────────────────────────
# Opciones: ollama | openai
# - ollama: gratis, corre en tu máquina. Modelo recomendado: nomic-embed-text
# - openai: pago, requiere OPENAI_API_KEY
EMBEDDING_PROVIDER=ollama

# Modelo de embeddings. Vacío = default del proveedor:
#   ollama → nomic-embed-text
#   openai → text-embedding-3-small
EMBEDDING_MODEL=

# ── Credenciales (rellena solo la del proveedor activo) ───────────────────────
OPENAI_API_KEY=

# ── Ollama (si EMBEDDING_PROVIDER=ollama) ─────────────────────────────────────
# Desarrollo local:
OLLAMA_BASE_URL=http://localhost:11434
# Dentro de Docker en Mac/Windows (Ollama corre en el host):
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Desarrollo local: ChromaDB corre en localhost:8004
CHROMA_HOST=localhost
CHROMA_PORT=8004
CHROMA_COLLECTION=thesis_docs
# Dentro de Docker el docker-compose sobreescribe CHROMA_HOST=chromadb y CHROMA_PORT=8000

# ── Upload storage ─────────────────────────────────────────────────────────────
# Desarrollo local: carpeta en tu máquina
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
