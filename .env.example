DATABASE_URL=postgresql://postgres:postgres@localhost:5432/irvinbot_docs
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256

# ── Embeddings ────────────────────────────────────────────────────────────────
# Opciones: ollama | openai
EMBEDDING_PROVIDER=ollama
# Modelo. Vacío = default del proveedor:
#   ollama → nomic-embed-text
#   openai → text-embedding-3-small
EMBEDDING_MODEL=

# ── Credenciales (solo la del proveedor activo) ───────────────────────────────
OPENAI_API_KEY=

# ── Ollama (si EMBEDDING_PROVIDER=ollama) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8004
CHROMA_COLLECTION=thesis_docs

# ── Upload storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=50
